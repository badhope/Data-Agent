{
  "providers": [
    {
      "type": "openai",
      "name": "openai-main",
      "apiKey": "${OPENAI_API_KEY}",
      "model": "gpt-4",
      "maxRetries": 3,
      "timeout": 60000
    },
    {
      "type": "openai",
      "name": "openai-backup",
      "apiKey": "${OPENAI_API_KEY}",
      "model": "gpt-3.5-turbo",
      "maxRetries": 3,
      "timeout": 30000
    },
    {
      "type": "anthropic",
      "name": "claude",
      "apiKey": "${ANTHROPIC_API_KEY}",
      "model": "claude-3-opus-20240229"
    },
    {
      "type": "ollama",
      "name": "ollama-local",
      "baseUrl": "http://localhost:11434",
      "model": "llama2"
    },
    {
      "type": "lmstudio",
      "name": "lmstudio-local",
      "baseUrl": "http://localhost:1234/v1",
      "model": "local-model"
    },
    {
      "type": "custom",
      "name": "custom-api",
      "baseUrl": "http://your-custom-api:8000/v1",
      "apiKey": "your-custom-key",
      "model": "custom-model"
    }
  ],
  "defaultProvider": "openai-main",
  "fallbackEnabled": true,
  "retryAttempts": 3,
  "timeout": 60000
}
