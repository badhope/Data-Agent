# ===========================================
# Data-Agent 智能办公助手 - 环境变量配置
# ===========================================
# 复制此文件为 .env 后修改配置
# Docker 部署时会自动读取此文件

# --- LLM 配置 ---
# OpenAI API Key（必需）
OPENAI_API_KEY=your-openai-api-key-here

# 禁用 LangSmith 追踪（本地开发建议关闭）
LANGSMITH_TRACING=false

# --- Chainlit 配置 ---
CHAINLIT_AUTH_SECRET=your-secret-key-here
CHAINLIT_SERVER_PORT=8000
